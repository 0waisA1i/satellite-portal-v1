# Copy this file to .env.local and fill in the values from Owais.
# Never commit .env.local. The service role key is secret and server-only.

# From Owais (Supabase project settings > API). Use a dev/staging project, not production.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by Server Components / server actions for gated reads. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
